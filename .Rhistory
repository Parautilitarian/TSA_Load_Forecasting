export_submission(forecast_nnetar,"NNETAR.csv")
clean_train <- tsclean(train_msts)
outliers <- which(train_msts != clean_train)
autoplot(train_msts) +
autolayer(clean_train, series = "Cleaned") +
autolayer(ts(train_msts[outliers],
start = time(train_msts)[outliers],
frequency = frequency(train_msts)),
series = "Outliers")
fit_mstl <- mstl(train_msts)
fit_ets <- ets(seasadj(fit_mstl))
fc_mstl <- forecast(fit_ets, h = length(valid_msts))
autoplot(fc_mstl) +
autolayer(valid_msts, series = "Actual", PI = FALSE) +
xlim(2010, 2010.6) +
ylab("electricity load")
export_submission(fc_mstl,"MSTL_ETS.csv")
fit_stlm <- stlm(train_msts, method = "ets")
fc_stlm <- forecast(fit_stlm, h = length(valid_msts))
autoplot(fc_stlm) +
autolayer(valid_msts, series = "Actual", PI = FALSE) +
xlim(2010, 2010.6) +
ylab("electricity load")
export_submission(fc_stlm,"STLM.csv")
library(prophet)
train_df <- data.frame(
ds = train_data$date,
y = train_data$daily_load
)
fit_prophet <- prophet(train_df)
future <- make_future_dataframe(fit_prophet,
periods = length(valid_msts),
freq = "day")
fc_prophet <- predict(fit_prophet, future)
plot(fit_prophet, fc_prophet)
export_submission(fc_prophet,"Prophet.csv")
fit_theta <- thetaf(train_ts, h = length(valid_ts))
autoplot(fit_theta) +
autolayer(valid_ts, series = "Actual", PI = FALSE) +
xlim(2010, 2010.6) +
ylab("electricity load")
export_submission(fit_theta,"Theta.csv")
best_aicc <- Inf
best_fit <- NULL
best_K <- NULL
for(k1 in 1:4){        # weekly
for(k2 in 1:10){     # yearly
xreg <- fourier(train_msts, K = c(k1, k2))
fit <- auto.arima(
train_msts,
xreg = xreg,
seasonal = FALSE
)
if(fit$aicc < best_aicc){
best_aicc <- fit$aicc
best_fit <- fit
best_K <- c(k1, k2)
}
}
}
best_aicc <- Inf
best_fit <- NULL
best_K <- NULL
for(k1 in 1:3){        # weekly (max 3)
for(k2 in 1:10){     # yearly (safe range)
xreg <- fourier(train_msts, K = c(k1, k2))
fit <- auto.arima(
train_msts,
xreg = xreg,
seasonal = FALSE
)
if(fit$aicc < best_aicc){
best_aicc <- fit$aicc
best_fit <- fit
best_K <- c(k1, k2)
}
}
}
best_K
{r}
K <- c(3, 1)   # 3 Fourier pairs for weekly, 5 for yearly
fourier_train <- fourier(train_msts, K = K)
fit_arima_fourier <- auto.arima(
